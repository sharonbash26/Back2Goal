{
    "manifest_version": 3,
    "name": "Back to Goal",
    "version": "1.0",
    "description": "Stay focused and minimize distractions with AI reminders.",
    "permissions": [
        "storage",
        "tabs"
    ],
    "action": {
        "default_popup": "popup.html"
    },
    "background": {
        "service_worker": "background.js"
    },
    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content.js"],
            "css": ["overlay.css"]
        }
    ]
}